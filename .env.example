# ─────────────────────────────────────────────
# Copy this file to .env and fill in your actual secrets
# Only set ONE API key option below.
# ─────────────────────────────────────────────

# OPTION A: Direct OpenAI (most common)
#   Get your key at https://platform.openai.com/api-keys
#   Use this if you have an OpenAI account.
# Uncomment the next line and fill in your key:
# OPENAI_API_KEY=sk-your-openai-api-key-here

# ── OR ──

# OPTION B: OpenRouter proxy (no separate OpenAI account needed)
#   Get your key at https://openrouter.ai/keys
#   Use this if you want to use OpenRouter as your LLM provider.
# Uncomment BOTH lines below and fill in your key:
OPENAI_API_KEY=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
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Do NOT set both options at the same time.

# Add any other environment variables below as needed
